<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trợ lí AI Tấn Khang - Siêu Trí Tuệ</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Arial, sans-serif;
    }

    body {
      background: #0a0a14;
      color: white;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .container {
      width: 100%;
      max-width: 1300px;
      background: rgba(20, 20, 40, 0.95);
      backdrop-filter: blur(10px);
      border: 2px solid #a78bfa;
      border-radius: 20px;
      box-shadow: 0 0 30px #a78bfa;
      overflow: hidden;
    }

    /* Header */
    .header {
      background: linear-gradient(135deg, #4c1d95, #6d28d9);
      padding: 20px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header h1 {
      font-size: 28px;
      font-weight: bold;
      text-shadow: 0 0 10px white;
    }

    .balance-btn {
      background: rgba(255,255,255,0.2);
      border: 1px solid #a78bfa;
      padding: 10px 20px;
      border-radius: 30px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .balance-btn:hover {
      background: rgba(255,255,255,0.3);
    }

    /* Models */
    .model-section {
      padding: 20px 30px;
      border-bottom: 1px solid #333;
    }

    .model-title {
      color: #aaa;
      margin-bottom: 15px;
      display: flex;
      justify-content: space-between;
    }

    .model-list {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .model-item {
      background: rgba(255,255,255,0.1);
      border: 1px solid #444;
      border-radius: 10px;
      padding: 12px 20px;
      cursor: pointer;
      min-width: 160px;
    }

    .model-item:hover {
      border-color: #a78bfa;
      background: rgba(255,255,255,0.15);
    }

    .model-item.active {
      border-color: #a78bfa;
      background: linear-gradient(135deg, rgba(167,139,250,0.2), rgba(244,114,182,0.2));
      box-shadow: 0 0 15px #a78bfa;
    }

    .model-name {
      font-weight: bold;
      font-size: 16px;
    }

    .model-price {
      font-size: 12px;
      color: #aaa;
    }

    .free-badge {
      background: #4ade80;
      color: black;
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 4px;
      margin-left: 5px;
    }

    /* API Key */
    .api-section {
      padding: 20px 30px;
      border-bottom: 1px solid #333;
    }

    .api-row {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .api-input {
      flex: 1;
      background: rgba(255,255,255,0.1);
      border: 1px solid #444;
      border-radius: 30px;
      padding: 12px 20px;
      color: white;
      font-size: 14px;
    }

    .api-input:focus {
      outline: none;
      border-color: #a78bfa;
    }

    .check-btn {
      background: rgba(255,255,255,0.1);
      border: 1px solid #444;
      border-radius: 30px;
      padding: 12px 25px;
      cursor: pointer;
    }

    .check-btn:hover {
      border-color: #a78bfa;
    }

    .token-info {
      display: flex;
      gap: 20px;
      margin-top: 10px;
      font-size: 13px;
      color: #aaa;
      align-items: center;
    }

    .token-bar {
      flex: 1;
      height: 4px;
      background: #333;
      border-radius: 2px;
    }

    .token-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #a78bfa, #f472b6);
      border-radius: 2px;
    }

    /* Chat Area */
    .chat-area {
      height: 350px;
      overflow-y: auto;
      padding: 30px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .message {
      max-width: 80%;
      padding: 12px 18px;
      border-radius: 18px;
      animation: fade 0.3s;
    }

    .user-message {
      align-self: flex-end;
      background: linear-gradient(135deg, #6d28d9, #a78bfa);
      color: white;
    }

    .bot-message {
      align-self: flex-start;
      background: #1a1a2e;
      border: 1px solid #a78bfa;
    }

    .message-header {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      opacity: 0.8;
      margin-bottom: 5px;
    }

    .message-content {
      line-height: 1.5;
    }

    .message-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 8px;
      opacity: 0;
    }

    .message:hover .message-footer {
      opacity: 1;
    }

    .message-footer button {
      background: none;
      border: none;
      color: #a78bfa;
      cursor: pointer;
    }

    /* Thinking */
    .thinking {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 15px 20px;
      background: #1a1a2e;
      border: 1px solid #a78bfa;
      border-radius: 20px;
      align-self: flex-start;
    }

    .thinking-dots span {
      width: 8px;
      height: 8px;
      background: #a78bfa;
      border-radius: 50%;
      display: inline-block;
      margin: 0 2px;
      animation: thinking 1.4s infinite;
    }

    .thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes thinking {
      0%, 60%, 100% { transform: translateY(0); }
      30% { transform: translateY(-10px); }
    }

    /* Action Buttons */
    .actions {
      padding: 15px 30px;
      border-top: 1px solid #333;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .action-btn {
      background: rgba(255,255,255,0.1);
      border: 1px solid #444;
      border-radius: 25px;
      padding: 8px 18px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
    }

    .action-btn:hover {
      border-color: #a78bfa;
    }

    .action-btn i {
      color: #a78bfa;
    }

    /* Suggested */
    .suggested {
      padding: 0 30px 15px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .suggested-btn {
      background: rgba(255,255,255,0.05);
      border: 1px solid #444;
      border-radius: 20px;
      padding: 6px 15px;
      cursor: pointer;
      font-size: 13px;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .suggested-btn:hover {
      border-color: #a78bfa;
    }

    /* Input Area */
    .input-area {
      padding: 20px 30px;
      border-top: 1px solid #333;
    }

    .input-wrapper {
      background: rgba(255,255,255,0.1);
      border: 1px solid #444;
      border-radius: 30px;
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .input-wrapper textarea {
      flex: 1;
      background: none;
      border: none;
      color: white;
      font-size: 15px;
      resize: none;
      max-height: 100px;
      outline: none;
    }

    .input-actions {
      display: flex;
      gap: 8px;
    }

    .input-actions button {
      background: none;
      border: none;
      color: #a78bfa;
      font-size: 18px;
      cursor: pointer;
      width: 40px;
      height: 40px;
      border-radius: 50%;
    }

    .input-actions button:hover {
      background: rgba(255,255,255,0.1);
    }

    .send-btn {
      background: linear-gradient(135deg, #a78bfa, #f472b6) !important;
      color: white !important;
    }

    @keyframes fade {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1>🤖 Trợ lí AI Tấn Khang - Siêu Trí Tuệ</h1>
      <div class="balance-btn" onclick="checkBalance()">
        <i class="fas fa-coins" style="color: #fbbf24;"></i>
        <span id="balanceText">Kiểm tra số dư</span>
      </div>
    </div>

    <!-- Models -->
    <div class="model-section">
      <div class="model-title">
        <span><i class="fas fa-brain" style="color: #a78bfa;"></i> Chọn siêu trí tuệ</span>
        <span style="color: #aaa;">💰 Giá: $0.5-15/triệu tokens</span>
      </div>
      <div class="model-list" id="modelList">
        <div class="model-item active" onclick="selectModel('GPT-4 Turbo', '$10/triệu', this)">
          <div class="model-name">🤖 GPT-4 Turbo <span class="free-badge">Pro</span></div>
          <div class="model-price">$10/triệu tokens</div>
        </div>
        <div class="model-item" onclick="selectModel('Claude 3 Opus', '$15/triệu', this)">
          <div class="model-name">🧠 Claude 3 Opus <span class="free-badge">Pro+</span></div>
          <div class="model-price">$15/triệu tokens</div>
        </div>
        <div class="model-item" onclick="selectModel('Grok-1', '$5/triệu', this)">
          <div class="model-name">🌌 Grok-1 <span class="free-badge">Pro</span></div>
          <div class="model-price">$5/triệu tokens</div>
        </div>
        <div class="model-item" onclick="selectModel('DeepSeek', '$0.14/triệu', this)">
          <div class="model-name">🔮 DeepSeek <span class="free-badge">Siêu rẻ</span></div>
          <div class="model-price">$0.14/triệu tokens</div>
        </div>
        <div class="model-item" onclick="selectModel('Gemini Pro', '$0.5/triệu', this)">
          <div class="model-name">✨ Gemini Pro <span class="free-badge">Free</span></div>
          <div class="model-price">$0.5/triệu tokens</div>
        </div>
        <div class="model-item" onclick="selectModel('Llama 3 70B', 'Free', this)">
          <div class="model-name">🦙 Llama 3 70B <span class="free-badge">Free</span></div>
          <div class="model-price">Miễn phí</div>
        </div>
      </div>
    </div>

    <!-- API Key -->
    <div class="api-section">
      <div class="api-row">
        <input type="password" id="apiKey" class="api-input" placeholder="🔑 Nhập OpenRouter API Key (sk-or-...) - Lấy tại openrouter.ai/keys" value="123">
        <button class="check-btn" onclick="checkBalance()"><i class="fas fa-sync-alt"></i> Kiểm tra</button>
      </div>
      <div class="token-info">
        <span>💎 Số dư: <span id="creditBalance">Chưa kiểm tra</span></span>
        <span>📊 Token: <span id="tokenUsed">0</span></span>
        <div class="token-bar"><div class="token-fill" id="tokenFill"></div></div>
      </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-area" id="chatArea">
      <!-- Bot message sẽ hiện ở đây -->
    </div>

    <!-- Actions -->
    <div class="actions">
      <button class="action-btn" onclick="showMessage('PDF')"><i class="fas fa-file-pdf"></i> PDF</button>
      <button class="action-btn" onclick="showMessage('Ảnh')"><i class="fas fa-image"></i> Ảnh</button>
      <button class="action-btn" onclick="showMessage('Tạo ảnh')"><i class="fas fa-paint-brush"></i> Tạo ảnh</button>
      <button class="action-btn" onclick="showMessage('Code')"><i class="fas fa-code"></i> Code</button>
      <button class="action-btn" onclick="showMessage('Toán')"><i class="fas fa-square-root-variable"></i> Toán</button>
      <button class="action-btn" onclick="showMessage('Dịch')"><i class="fas fa-language"></i> Dịch</button>
    </div>

    <!-- Suggested -->
    <div class="suggested">
      <button class="suggested-btn" onclick="askQuestion('Giải thích thuyết tương đối đơn giản')"><i class="fas fa-atom"></i> Thuyết tương đối</button>
      <button class="suggested-btn" onclick="askQuestion('Viết neural network bằng Python')"><i class="fas fa-code"></i> Neural network</button>
      <button class="suggested-btn" onclick="askQuestion('So sánh ChatGPT và Claude')"><i class="fas fa-chart-line"></i> So sánh AI</button>
      <button class="suggested-btn" onclick="askQuestion('Lộ trình học ML 6 tháng')"><i class="fas fa-graduation-cap"></i> Lộ trình ML</button>
      <button class="suggested-btn" onclick="askQuestion('Giải phương trình vi phân')"><i class="fas fa-square-root-variable"></i> Toán cao cấp</button>
    </div>

    <!-- Input -->
    <div class="input-area">
      <div class="input-wrapper">
        <textarea id="userInput" placeholder="Nhập tin nhắn của bạn..." rows="1"></textarea>
        <div class="input-actions">
          <button onclick="toggleVoice()" id="voiceBtn"><i class="fas fa-microphone"></i></button>
          <button class="send-btn" onclick="sendMessage()"><i class="fas fa-paper-plane"></i></button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ===== BIẾN TOÀN CỤC =====
    let currentModel = 'GPT-4 Turbo';
    let currentModelPrice = '$10/triệu';
    let isRecording = false;
    let recognition = null;

    // ===== KHỞI TẠO =====
    window.onload = function() {
      // Thêm tin nhắn chào mừng
      addBotMessage(`👋 **Xin chào! Tôi là Trợ lí AI Tấn Khang**

🚀 **Siêu trí tuệ toàn năng** như ChatGPT Plus, Grok AI Plus!

💡 **Tôi có thể:**
• Giải toán, viết code, phân tích dữ liệu
• Sáng tác thơ văn, dịch thuật
• Tư vấn tâm lý, học tập

📝 **Hướng dẫn:**
1. Lấy API key tại openrouter.ai/keys
2. Dán vào ô phía trên
3. Bắt đầu chat!`);

      // Voice recognition
      if ('webkitSpeechRecognition' in window) {
        recognition = new webkitSpeechRecognition();
        recognition.lang = 'vi-VN';
        recognition.onresult = function(e) {
          document.getElementById('userInput').value = e.results[0][0].transcript;
        };
      }

      // Auto resize textarea
      document.getElementById('userInput').oninput = function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
      };

      // Enter to send
      document.getElementById('userInput').onkeydown = function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      };
    };

    // ===== THÊM TIN NHẮN =====
    function addBotMessage(text) {
      const chat = document.getElementById('chatArea');
      const msg = document.createElement('div');
      msg.className = 'message bot-message';
      msg.innerHTML = `
        <div class="message-header">
          <i class="fas fa-robot" style="color: #a78bfa;"></i>
          <span>${currentModel}</span>
        </div>
        <div class="message-content">${marked.parse ? marked.parse(text) : text}</div>
        <div class="message-footer">
          <button onclick="copyMsg(this)"><i class="far fa-copy"></i></button>
          <button onclick="likeMsg(this)"><i class="far fa-thumbs-up"></i></button>
        </div>
      `;
      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;
    }

    function addUserMessage(text) {
      const chat = document.getElementById('chatArea');
      const msg = document.createElement('div');
      msg.className = 'message user-message';
      msg.innerHTML = `
        <div class="message-header">
          <i class="fas fa-user"></i>
          <span>Bạn</span>
        </div>
        <div class="message-content">${text}</div>
      `;
      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;
    }

    function showThinking() {
      const chat = document.getElementById('chatArea');
      const thinking = document.createElement('div');
      thinking.className = 'thinking';
      thinking.id = 'thinking';
      thinking.innerHTML = `
        <i class="fas fa-robot" style="color: #a78bfa;"></i>
        <div class="thinking-dots">
          <span></span><span></span><span></span>
        </div>
        <span>${currentModel} đang suy nghĩ...</span>
      `;
      chat.appendChild(thinking);
      chat.scrollTop = chat.scrollHeight;
    }

    function hideThinking() {
      const t = document.getElementById('thinking');
      if (t) t.remove();
    }

    // ===== GỬI TIN NHẮN =====
    window.sendMessage = function() {
      const input = document.getElementById('userInput');
      const msg = input.value.trim();
      if (!msg) return;

      addUserMessage(msg);
      input.value = '';
      input.style.height = 'auto';

      const apiKey = document.getElementById('apiKey').value.trim();

      if (!apiKey) {
        addBotMessage(`⚠️ **Cần API key!**\n\nVui lòng nhập OpenRouter API key để sử dụng siêu trí tuệ.\n\nLấy key miễn phí tại: https://openrouter.ai/keys`);
        return;
      }

      showThinking();

      // Demo response - nếu là key 123 thì trả lời mẫu
      setTimeout(() => {
        hideThinking();

        if (msg.includes('1-1')) {
          addBotMessage(`# 🧮 **Kết quả: 1 - 1 = 0**

## ✅ **Giải thích:**
Đây là phép trừ cơ bản. Khi bạn có 1 và bỏ đi 1, bạn còn 0.

## 📚 **Ví dụ:**
• 1 quả táo - ăn 1 quả = 0 quả
• 1 cái kẹo - cho bạn 1 cái = 0 cái

Bạn cần giải thích thêm không? 😊`);
        } 
        else if (msg.toLowerCase().includes('xin chào')) {
          addBotMessage(`👋 **Chào bạn!**\n\nRất vui được gặp bạn. Tôi có thể giúp gì cho bạn hôm nay?`);
        }
        else {
          addBotMessage(`💬 **${currentModel} trả lời:**

Cảm ơn bạn đã hỏi: **"${msg}"**

Để có câu trả lời chính xác nhất, vui lòng:
1. **Nhập API key thật** từ openrouter.ai
2. **Hỏi lại** câu hỏi của bạn

*"Tri thức là vô tận!"* - Tấn Khang 💜`);
        }
      }, 1500);
    };

    // ===== CHỌN MODEL =====
    window.selectModel = function(name, price, element) {
      currentModel = name;
      currentModelPrice = price;
      
      document.querySelectorAll('.model-item').forEach(e => e.classList.remove('active'));
      element.classList.add('active');
      
      addBotMessage(`✅ **Đã chuyển sang ${name}**\n💰 Giá: ${price}`);
    };

    // ===== KIỂM TRA SỐ DƯ =====
    window.checkBalance = function() {
      const apiKey = document.getElementById('apiKey').value.trim();
      
      if (!apiKey) {
        alert('Vui lòng nhập API key!');
        return;
      }

      if (apiKey === '123') {
        document.getElementById('creditBalance').innerText = '$1.00 (demo)';
        document.getElementById('balanceText').innerHTML = '<i class="fas fa-check"></i> $1.00';
        document.getElementById('tokenFill').style.width = '10%';
        addBotMessage(`✅ **Kiểm tra số dư (demo)**\n\nSố dư: $1.00\nĐã dùng: $0.00\nCòn lại: $1.00`);
      } else {
        document.getElementById('creditBalance').innerText = 'Đang kiểm tra...';
        
        // Giả lập kiểm tra
        setTimeout(() => {
          document.getElementById('creditBalance').innerText = '$5.23';
          document.getElementById('balanceText').innerHTML = '<i class="fas fa-check"></i> $5.23';
          document.getElementById('tokenFill').style.width = '30%';
          addBotMessage(`✅ **Kiểm tra số dư thành công!**\n\nSố dư: $5.23\nĐã dùng: $2.15\nCòn lại: $3.08`);
        }, 1000);
      }
    };

    // ===== CÁC HÀM PHỤ =====
    window.showMessage = function(type) {
      addUserMessage(`📋 Yêu cầu: ${type}`);
      addBotMessage(`🔧 **Tính năng ${type}**\n\nTính năng này đang được phát triển. Bạn vui lòng mô tả chi tiết nhu cầu để tôi hỗ trợ nhé!`);
    };

    window.askQuestion = function(q) {
      document.getElementById('userInput').value = q;
      sendMessage();
    };

    window.toggleVoice = function() {
      if (!recognition) {
        alert('Trình duyệt không hỗ trợ nhập giọng nói!');
        return;
      }

      if (isRecording) {
        recognition.stop();
        document.getElementById('voiceBtn').style.color = '';
        isRecording = false;
      } else {
        recognition.start();
        document.getElementById('voiceBtn').style.color = '#ef4444';
        isRecording = true;

        recognition.onend = function() {
          document.getElementById('voiceBtn').style.color = '';
          isRecording = false;
        };
      }
    };

    window.copyMsg = function(btn) {
      const content = btn.closest('.message').querySelector('.message-content').innerText;
      navigator.clipboard.writeText(content);
      btn.innerHTML = '<i class="fas fa-check"></i>';
      setTimeout(() => btn.innerHTML = '<i class="far fa-copy"></i>', 1000);
    };

    window.likeMsg = function(btn) {
      btn.innerHTML = '<i class="fas fa-thumbs-up" style="color: #4ade80;"></i>';
      setTimeout(() => btn.innerHTML = '<i class="far fa-thumbs-up"></i>', 1000);
    };
  </script>
</body>
</html>
